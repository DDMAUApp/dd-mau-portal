{
  "name": "dd-mau-portal",
  "private": true,
  "version": "1.0.304",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backup": "node scripts/backup-firestore.mjs",
    "backup-all": "node scripts/backup-all.mjs",
    "cors-setup": "node scripts/setup-storage-cors.mjs",
    "snapshot": "node scripts/make-code-snapshot.mjs",
    "sync-toast-employees": "node scripts/pull-toast-employees.mjs",
    "sync-toast-86": "node scripts/sync-toast-86-attribution.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "capgo:upload": "npx @capgo/cli@latest bundle upload --apikey $CAPGO_TOKEN",
    "capgo:upload-dev": "npx @capgo/cli@latest bundle upload --apikey $CAPGO_TOKEN --channel dev",
    "ship": "npm run build && git push && npx cap sync && npx @capgo/cli@latest bundle upload --apikey $CAPGO_TOKEN",
    "deploy": "bash scripts/deploy.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "rollback": "bash scripts/rollback.sh"
  },
  "dependencies": {
    "@capgo/capacitor-native-biometric": "^8.4.11",
    "@capgo/capacitor-printer": "^8.0.14",
    "@sentry/react": "^10.54.0",
    "@sentry/vite-plugin": "^5.3.0",
    "exceljs": "^4.4.0",
    "firebase": "^11.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-updater": "^8.47.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "firebase-admin": "^12.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  }
}
