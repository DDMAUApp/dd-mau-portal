// DD Mau Firestore security rules
//
// ── SECURITY POSTURE (2026-05-11 audit) ─────────────────────────────────
//
// CURRENT STATE: this app uses ANONYMOUS Firestore access (no per-user
// Firebase Auth). All access gates are client-side React checks. A
// curious staff member with DevTools could in theory bypass the UI and
// run getDocs() directly to read PII-heavy collections.
//
// MITIGATIONS IN PLACE TODAY (defense-in-depth around the client gate):
//   • SSN is never written to Firestore — it lives only inside the
//     hire's filled W-4 PDF in Storage, which uses a non-enumerable
//     hireId in the path.
//   • Hire records use Firestore-generated random doc IDs — they can be
//     read in bulk if you can list the collection, but you can't guess
//     a specific one to target.
//   • All admin views/downloads/approvals on PII land in /onboarding_audits
//     so any insider abuse leaves a trail.
//   • Apply form submissions require createdAt == request.time so old
//     payloads can't be replayed and timestamps can't be forged.
//   • The PIN screen rate-limits attempts (HomePage.jsx) and locks on
//     close + 5-min idle (App.jsx).
//
// PHASE 2 (MUST-DO before scaling beyond DD Mau's current team):
//   1. Wire Firebase Auth — sign every staff in with email/password (or
//      passwordless email link). Replace localStorage staffName with an
//      Auth session.
//   2. Set custom claims on each user: { admin: true, canViewOnboarding:
//      true, opsAccess: true, ... } via a Cloud Function callable.
//   3. Rewrite these rules to gate by claim:
//        match /onboarding_hires/{hireId} {
//          allow read: if request.auth.token.canViewOnboarding == true;
//          allow write: if request.auth.token.canViewOnboarding == true;
//        }
//   4. Same in storage.rules using request.auth.token.canViewOnboarding.
//   5. Enable App Check (recaptcha v3 + iOS DeviceCheck) to keep
//      non-app traffic out entirely.
//
// ── PRIORITY: protect /config/staff from PIN corruption ────────────────
// The 2026-05-09 incident showed that any buggy client could overwrite
// the entire staff list (including all PINs) by sending an `update` with
// stale data. These rules enforce on the SERVER that:
//
//   1. Every staff record in any write must have pin = exactly 4 digits.
//      A write with empty / null / non-4-digit PIN on ANY record is REJECTED.
//      This catches the bug class where stale React state (DEFAULT_STAFF
//      pre-snapshot, with empty pins) gets written back.
//
//   2. The list size cannot shrink unexpectedly. If the new list is more
//      than 5 records smaller than the existing list, REJECT — that's
//      almost certainly a bug, not a real bulk delete.
//
// Other collections currently allow read+write for any authenticated
// device (matches existing app behavior). Tighten later as we add per-
// collection rules.
//
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // NOTE on per-record PIN validation:
    // Firestore security rules do NOT support array iteration (no .where(),
    // no for-loops, no .map). We can't validate the structure of every
    // staff record server-side. Per-record validation lives in the CLIENT
    // (saveStaffToFirestore in AdminPanel.jsx — the PIN integrity gate).
    // Server-side defense here is bounded to size-shrink protection.

    // Staff document — the high-value target.
    match /config/staff {
      allow read: if true; // staff list is read by every signed-in device
      allow create: if request.resource.data.list is list;
      allow update: if
        request.resource.data.list is list &&
        request.resource.data.list.size() > 0 &&
        // Don't shrink the list by more than 5 in a single write.
        // Bulk-removing more than that should be a deliberate admin script,
        // not a runtime UI write.
        (
          !('list' in resource.data) ||
          request.resource.data.list.size() >= resource.data.list.size() - 5
        );
      // No deletes — the staff doc should never be deleted from a client.
      allow delete: if false;
    }

    // forceRefresh broadcast — admins write a timestamp to trigger reload
    // on every device. Read by all clients.
    //
    // Hardened 2026-05-17 (SEC-007): the previous `allow read, write: if
    // true` let anyone with the Firebase apiKey trigger a mass reload of
    // every staff device at will. We now require the write to look like
    // a real broadcast — must carry `triggeredBy` (a name string) and
    // `triggeredAt` must equal request.time (i.e. a freshly-generated
    // serverTimestamp, no replay). A determined attacker can still
    // fabricate this payload; the real fix is Firebase Auth + admin
    // claim, but this stops casual abuse + makes mass-reload writes
    // traceable in audit replay.
    match /config/forceRefresh {
      allow read: if true;
      allow write: if request.resource.data.triggeredBy is string
                   && request.resource.data.triggeredAt == request.time;
    }

    // Inbox routing rules — owner-only forwarding configuration (Andrew
    // 2026-05-26). Master killswitch + per-category recipient lists.
    // Client UI in InboxTriage is gated to admin ids 40/41. Without
    // Firebase Auth we can't strictly enforce that at the rules level,
    // so we accept map-shaped writes for now (same posture as other
    // admin-gated config docs in this file). Phase 2 will tighten via
    // custom claims.
    match /config/inbox_routing_rules {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if false;
    }

    // Inbox category list (Andrew 2026-05-26). Editable category
    // taxonomy. Admin-gated client-side; pollGmail reads it at the
    // start of every run to build the classifier prompt. Same Phase-2
    // tightening planned as inbox_routing_rules.
    match /config/inbox_categories {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if false;
    }

    // Toast menu items map (Andrew 2026-05-26). GUID→name lookup
    // written by scripts/sync-toast-86-attribution.mjs every run.
    // Eighty6Dashboard reads it to resolve any item still stored
    // with a raw Toast GUID as its name. Script-only writes (admin
    // SDK bypasses these rules); clients are read-only.
    match /config/toast_menu_items {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── SaaS-ready menu config (Andrew 2026-05-30, Phase 1.A) ────
    // Three docs that move the menu, brand identity, and build
    // sheet out of hardcoded JS into Firestore so an admin can
    // edit any of it through the editor UI (Phase 1.B–1.D) without
    // a code push. See src/data/menuConfig.js for the writer API.
    //
    // Read posture: open (read by every TV + every staff phone).
    // Write posture: shape-validated server-side; admin-gated in
    // the client (the editor only renders for staffIsAdmin).
    //
    // /config/menu_v2 — categories[] with items[]. Hard cap of
    // 50 categories and 500 items total to prevent runaway writes
    // from a buggy client. updatedAt monotonicity rejects stale
    // offline-cache flushes (same pattern as /config/recipes).
    match /config/menu_v2 {
      allow read: if true;
      allow create: if
        request.resource.data.categories is list &&
        request.resource.data.categories.size() <= 50 &&
        request.resource.data.schemaVersion is int;
      allow update: if
        request.resource.data.categories is list &&
        request.resource.data.categories.size() <= 50 &&
        request.resource.data.schemaVersion is int;
      allow delete: if false;
    }

    // /config/brand — restaurant name, cuisine type, location
    // labels. Small map doc, no list-size limits needed.
    match /config/brand {
      allow read: if true;
      allow create, update: if
        request.resource.data is map &&
        request.resource.data.schemaVersion is int;
      allow delete: if false;
    }

    // /config/build_sheet — toppings/modifiers/broths/sauces.
    // `sections` is a map of named arrays (bowls, handhelds, etc.).
    match /config/build_sheet {
      allow read: if true;
      allow create, update: if
        request.resource.data.sections is map &&
        request.resource.data.schemaVersion is int;
      allow delete: if false;
    }

    // Onboarding doc-text overrides (Andrew 2026-05-28). Lets admins
    // edit the description shown to hires for any ONBOARDING_DOCS
    // entry — e.g. add "you have 30 days from hire date" to the Hep A
    // wording. Shape: { overrides: { [docId]: { en, es } }, updatedAt,
    // updatedBy }. Read open (the hire portal needs it on bare
    // /?onboard=TOKEN routes); writes are admin-gated client-side
    // (only the Onboarding tab UI exposes the editor, and that tab is
    // restricted to canViewOnboarding staff). Map-shape check is the
    // same posture as inbox_routing_rules / inbox_categories above.
    match /config/onboarding_doc_text {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if false;
    }

    // Recipes doc — hardened after the 2026-05-09 Import Master incident.
    // The bug clobbered 39 of 40 recipes in a single write by replacing
    // each one with a master-default version. Since the doc is one giant
    // `list` array, every save touches the whole thing — meaning the
    // blast radius of one bad write is "everything."
    //
    // Rules below are defense-in-depth (the Import Master button is also
    // removed from the client). Server-side enforcement means even a
    // future buggy client can't reproduce the same blast radius.
    //
    // Allowed write profile:
    //   • list is a non-empty array, sane upper bound (200)
    //   • updatedAt is present and STRICTLY increasing (rejects stale
    //     offline-cache flushes that try to overwrite newer server state)
    //   • list size doesn't shrink by more than 5 per write (catches
    //     mass-delete bugs)
    //   • list size doesn't grow by more than 10 per write (catches
    //     bulk-import bugs like the one we just removed)
    //
    // What this does NOT catch: a bad write that REPLACES the same
    // number of recipes with different content (the actual incident
    // pattern). Per-save audit log in /recipe_audits + the removed
    // Import Master button cover that case.
    match /config/recipes {
      allow read: if true;
      allow create: if
        request.resource.data.list is list &&
        request.resource.data.list.size() > 0 &&
        request.resource.data.list.size() <= 200 &&
        request.resource.data.updatedAt is string;
      allow update: if
        request.resource.data.list is list &&
        request.resource.data.list.size() > 0 &&
        request.resource.data.list.size() <= 200 &&
        request.resource.data.updatedAt is string &&
        // updatedAt must move forward — reject stale flushes
        request.resource.data.updatedAt > resource.data.updatedAt &&
        // Don't shrink by more than 5
        request.resource.data.list.size() >= resource.data.list.size() - 5 &&
        // Don't grow by more than 10
        request.resource.data.list.size() <= resource.data.list.size() + 10;
      // Recipes doc must never be deleted from a client.
      allow delete: if false;
    }

    // PIN audit log — append-only from clients, read by anyone (admin
    // sees it in the dashboard). NEVER modifiable or deletable.
    match /pin_audits/{auditId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Inventory change audit log — one doc per +/- count change. Two
    // collections (one per location): inventory_audits_webster and
    // inventory_audits_maryland. Append-only so the audit trail can't
    // be tampered with after the fact.
    // Use case (Andrew, 2026-05-12): reconstruct who tweaked counts when,
    // for items that ended up missing from the order.
    //
    // NOTE: Firestore rules do NOT support partial-segment variable
    // substitution (a previous version had `/inventory_audits_{location}/`
    // which silently failed to deploy). Each location gets its own
    // explicit match block.
    match /inventory_audits_webster/{auditId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /inventory_audits_maryland/{auditId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Recipe audit log — append-only from clients, captures BEFORE/AFTER
    // state of every recipe save/delete (paired with writeRecipeAudit() in
    // Recipes.jsx). Lets us roll back any single recipe to any point in
    // history. NEVER modifiable or deletable — that would defeat the
    // whole purpose of an audit log.
    match /recipe_audits/{auditId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Backup history — written by the scheduledFirestoreBackup Cloud
    // Function (admin SDK bypasses these rules). Clients can READ to
    // surface "last backup ran X hours ago" indicators in the admin
    // dashboard. Append-only to clients (in case we ever want to log
    // a manual-trigger backup from the UI).
    match /backup_history/{auditId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // ── Onboarding (PII) ────────────────────────────────────────────────
    // Holds new-hire records with SSN/DOB/uploaded W4 etc. CRITICAL: these
    // rules must come BEFORE the permissive {document=**} fallback below,
    // otherwise the catch-all wins and anyone signed in can read PII.
    //
    // This app currently uses anonymous Firestore access (no per-user
    // auth). Until we wire individual auth, the strongest server-side
    // enforcement we can do is: narrow each collection's allowed write
    // shape, keep file contents in Storage (which has its own rules),
    // and rely on the CLIENT gate (canViewOnboarding flag in
    // /config/staff.list) to hide the admin tab from non-admins.
    //
    // INVITES + APPLICATIONS are public-write by design: a hire needs to
    // submit data without being signed in. Schema is narrowed; abuse is
    // mitigated by short token lifetime + admin manual triage.

    // Admin-owned hire records — full PII metadata (file contents live
    // in Storage). Read is open at the rules layer because the new-hire
    // portal reads its own record after resolving an invite token; the
    // admin tab is gated client-side via canViewOnboarding.
    //
    // Hardened 2026-06-02 (Phase 1 audit). Previously `update: if true`
    // let any apiKey holder rewrite arbitrary fields on any hire —
    // including overwriting completed `personal` (DOB, address) or
    // `bankAccount` (direct deposit) blocks, or replacing the
    // `finalCertification` signature record. Without Firebase Auth
    // (Phase 2) we cannot bind the writer to the hire identity, but we
    // CAN enforce:
    //   1. The write must be a map (rejects raw-string / null
    //      payloads that come from buggy clients).
    //   2. PII-bearing top-level fields (`personal`, `emergencyContact`,
    //      `bankAccount`, `finalCertification`), if present in the
    //      write, must themselves be maps. Stops the specific abuse
    //      vector "POST personal: null" or "POST bankAccount: 'foo'"
    //      that destroys completed PII or trips renderer null-checks.
    //   3. The hire's own `id` and original `createdAt` cannot be
    //      flipped — those anchor audit reconstruction.
    //
    // What this does NOT enforce (Phase 2 / Firebase Auth closes it):
    //   • Distinguishing the hire (filling their own portal) from a
    //     stranger with the apiKey rewriting another hire's PII.
    //   • Truly immutable PII once submitted — the portal still allows
    //     the hire to fix a typo in their DOB before final cert, and a
    //     hostile apiKey holder could mimic that flow. The right lock
    //     is a hireId-scoped Auth claim, not a rules-level diff.
    //
    // Audit trail: every admin view / approve / download lands in
    // /onboarding_audits, so any out-of-band PII rewrite is traceable.
    match /onboarding_hires/{hireId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['id', 'name', 'createdAt'])
                    && request.resource.data.name is string;
      allow update: if request.resource.data is map
                    // PII top-level fields, if present, must be maps —
                    // blocks the "null over personal" class of abuse.
                    && (!('personal' in request.resource.data)
                        || request.resource.data.personal is map)
                    && (!('emergencyContact' in request.resource.data)
                        || request.resource.data.emergencyContact is map)
                    && (!('bankAccount' in request.resource.data)
                        || request.resource.data.bankAccount is map)
                    && (!('finalCertification' in request.resource.data)
                        || request.resource.data.finalCertification is map)
                    // Hire identity anchors cannot be rewritten.
                    && (!('id' in request.resource.data)
                        || !('id' in resource.data)
                        || request.resource.data.id == resource.data.id)
                    && (!('createdAt' in request.resource.data)
                        || !('createdAt' in resource.data)
                        || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if false;      // archive flag instead of hard-delete
    }

    // Invite tokens — single-use, time-boxed. The new-hire portal reads
    // its own invite by token id (the URL param), then loads the hire.
    //
    // Hardened 2026-05-30 (CR-3): `update: if true` previously let any
    // caller rewrite `hireId` on an existing invite — i.e. steal a token
    // that was minted for hire A and repoint it to hire B. We now hold
    // `hireId` immutable across updates so the only thing that can change
    // is the status flip (markUsed / openedAt / etc.). Phase 2 (Firebase
    // Auth) will close this entirely; this is the right gate to add now.
    match /onboarding_invites/{token} {
      allow read: if true;
      allow create: if request.resource.data.hireId is string
                    && request.resource.data.expiresAt is string;
      allow update: if request.resource.data is map
                    && request.resource.data.hireId == resource.data.hireId;
      allow delete: if false;
    }

    // Public application submissions from the lock-screen Apply button.
    // Append-only from anyone; admins read + clean up after converting.
    //
    // RATE LIMITING: real anti-spam requires per-IP tracking which needs
    // a Cloud Function. Honest best-effort here: require the submission's
    // own createdAt to be a serverTimestamp (set by the client SDK to
    // request.time). This prevents replay of old payloads and far-future
    // submissions. Doesn't prevent flood from a single attacker, but
    // raises the cost of automation (each request has to be live, not
    // canned). Client-side 60s cooldown is the second line of defense.
    //
    // The shape narrowing (name is string, length 2..200) discourages
    // empty-payload spam. Other fields are optional to keep the form
    // permissive for legit applicants.
    // Hardened 2026-05-30 (CR-4): split update + delete. Previously
    // `update, delete: if true` let any caller wipe an application or
    // overwrite a submitted payload. Real lifecycle:
    //   • Admin updates status / notes / interview state from the UI
    //     (kept open as map-shape — no Auth yet to pin to admin claim)
    //   • Hard delete is owned by the expireAndPurgeApplications Cloud
    //     Function (admin SDK bypasses rules). No client-side delete
    //     path exists in the app today, so denying delete here doesn't
    //     break any flow.
    //
    // Hardened 2026-06-02 (Phase 1 audit). Previously `update: if
    // request.resource.data is map` let any apiKey holder rewrite a
    // submitted applicant's name / email / phone, breaking integrity
    // of the application history. Application CONTENT is now immutable
    // post-submit; only triage-state fields can change. Specifically:
    //   • name + email + phone + createdAt + role + city + state + zip +
    //     coverLetter + (any other content field) — must equal the
    //     existing value on every update.
    //   • status + statusUpdatedAt + statusUpdatedBy + starredBy +
    //     hireId — admin triage state, freely writable from the
    //     Onboarding tab.
    //
    // We can't enumerate every legitimate "content" field in rules, so
    // we go the other way: pin the small set of identity fields that
    // ABSOLUTELY must not change. `name` is the strongest anchor (every
    // application carries one; the apply form requires it). Pinning
    // name + createdAt is sufficient to prevent the "rewrite Bob's
    // application as Alice's" abuse without enumerating every optional
    // field on the form.
    match /onboarding_applications/{appId} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 1
                    && request.resource.data.name.size() < 200
                    && request.resource.data.createdAt == request.time;
      allow update: if request.resource.data is map
                    // Identity anchors — once submitted, these can
                    // never change. Blocks "rewrite an application's
                    // applicant name + createdAt" abuse.
                    && (!('name' in resource.data)
                        || request.resource.data.name == resource.data.name)
                    && (!('createdAt' in resource.data)
                        || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if false;
    }

    // Onboarding audit trail — every admin view/download/approve/reject.
    // Append-only.
    match /onboarding_audits/{auditId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Onboarding fillable PDF templates — admin uploads W-4, MO W-4, DD
    // form once, marks field positions, and every hire fills the same
    // template in-browser. Templates are not PII themselves; the PDF
    // bytes live in Storage at onboarding_templates/{templateId}.pdf.
    //
    // Hardened 2026-06-02 (Phase 1 audit). Previously `delete: if true`
    // let any apiKey holder wipe the entire template library — every
    // hire's W-4 / MO W-4 / Direct Deposit fillable would break until
    // an admin re-uploaded them. Templates are recoverable but not
    // routinely deleted (admin uploads each one ONCE). The
    // OnboardingTemplateEditor.removeTemplate path now fails fast at
    // the rules layer; the legitimate workflow for removing an old
    // template is via Firebase Console (or a future admin-callable
    // Cloud Function). The trade-off is intentional: the rare admin-
    // delete moves out of the client UI; the common abuse vector
    // (mass-wipe via tampered client) closes.
    match /onboarding_templates/{templateId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
                            && request.resource.data.forDocId is string;
      allow delete: if false;
    }

    // Training content overrides — admins edit lesson title + bullets
    // inline in the app and the changes propagate to every device via
    // this doc. The TrainingHub gates the Edit button by isAdmin()
    // client-side; these rules are defense-in-depth.
    //
    // Doc shape: { [`${moduleId}__${lessonId}`]: { titleEn, titleEs,
    // contentEn[], contentEs[], editedBy, editedAt }, ... }.
    //
    // SECURITY POSTURE: same as /config/staff and /config/recipes.
    // Without Firebase Auth (Phase 2 roadmap), we cannot truly verify
    // the writer is an admin — any signed-in device knowing the path
    // could write. What we CAN enforce server-side:
    //
    //   1. Reads stay open (lessons render to every staff).
    //   2. Doc must be a map. No replacing it with a non-object.
    //   3. NO DELETES from clients. Wiping the whole doc reverts every
    //      in-app edit at once — must be a deliberate admin script.
    //   4. Growth cap — a write can add at most 5 new keys at a time,
    //      catching the bug where a buggy client posts a payload with
    //      hundreds of fabricated overrides.
    //
    // Per-key shape validation (each value must be {titleEn, titleEs,
    // contentEn, contentEs, ...}) is NOT enforceable in rules because
    // Firestore can't iterate a map's dynamic keys. A bad write that
    // sets one key to garbage data would pass — the Edit button only
    // surfaces the doc to admins and the renderer falls back to the
    // static MODULES when override fields are absent or wrong-shape,
    // so impact is bounded to that single lesson.
    match /config/training_overrides {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.size() <= 100;
      allow update: if request.resource.data is map
                    && request.resource.data.size() <= 100
                    && (
                      !('keys' in resource.data) ||
                      request.resource.data.size() <= resource.data.size() + 5
                    );
      allow delete: if false;
    }

    // Rate-limit buckets — written only by Cloud Functions (admin SDK
    // bypasses these rules). Clients have no business reading or
    // writing here; sealing it shut prevents a tampered client from
    // resetting its own counter to bypass the limit. (Added 2026-05-17
    // alongside the translateMessage rate limiter, SEC-002.)
    match /rate_limits/{bucketId} {
      allow read, write: if false;
    }

    // Audit log — append-only.
    //
    // Hardened 2026-05-17 (SEC-005). Previously this collection inherited
    // the open catch-all below, which meant any signed-in device could
    // delete + rewrite audit history. That defeats the entire point of
    // having an audit log (forensic reconstruction after a security
    // incident, payroll dispute, recipe revert, etc.).
    //
    // Now: append-only. Read is open so the admin panel can render it;
    // create requires the shape that recordAudit() in src/data/audit.js
    // already writes (action + actorName + createdAt as server timestamp);
    // update + delete are forever forbidden from clients. A future Cloud
    // Function with admin SDK access can prune old entries (>2 years)
    // — that bypasses these rules legitimately.
    //
    // Why createdAt == request.time: it forces every audit doc to carry
    // a freshly-issued server timestamp. Stale-payload replay attacks
    // (write an audit with a forged actorName + an old timestamp) get
    // rejected.
    match /audit/{auditId} {
      allow read: if true;
      allow create: if request.resource.data.action is string
                    && request.resource.data.actorName is string
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // ── Chats — tombstone deletes only ─────────────────────────────────
    // Chat documents (group/DM metadata) and their messages should never
    // be hard-deleted from clients. The chat surface deletes via tombstone
    // (set `deletedAt` and `deletedReason`); the rules enforce that the
    // doc itself stays around so audit replay can reconstruct who sent
    // what and when. This was always the app's intent — the rule just
    // makes it server-enforceable. (Andrew 2026-05-23.)
    //
    // Message-level: same posture — the existing client code only updates
    // a message's `deleted: true` tombstone field, never calls deleteDoc.
    // Codifying that here closes the gap where a buggy or hostile client
    // could permanently erase chat history.
    match /chats/{chatId} {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if true;
        allow create, update: if request.resource.data is map;
        allow delete: if false;
      }
    }

    // ── Notifications — append + soft-update only ──────────────────────
    // /notifications is the FCM/SMS fan-out queue. Every doc is created
    // by a client (or a Cloud Function), processed by dispatchNotification,
    // and marked `read` later. Hard-deleting one would lose the audit
    // trail of "did this push actually fire?". Block delete here; the
    // scheduledFirestoreBackup function uses admin SDK and bypasses
    // these rules if we ever want to prune old notifications server-side.
    //
    // 2026-05-24 — SERVER-ONLY TYPE LOCKDOWN. Before this, anyone with
    // the public Firebase apiKey could mint a doc with `type:
    // "shift_reminder_1h"` (or tv_offline / tv_back_online / i9_reverify_due)
    // and trick dispatchNotification + dispatchSms into firing real
    // push + paid Twilio SMS to any staff. These types are NEVER
    // created by client code — only by Cloud Functions (sendShiftReminders,
    // checkTvHeartbeats, i9ReverificationReminder). Cloud Functions bypass
    // these rules via admin SDK, so they keep working. Adding new
    // CF-only types? Update this list AND the function that creates them.
    //
    // Note: this does NOT close the SMS-spam vector for client-mintable
    // types like coverage_request or urgent_announcement — those can
    // still be abused. dispatchSms enforces a per-recipient cooldown
    // (see functions/index.js) as the second line of defense. Phase 2
    // (Firebase Auth + admin claims) closes the rest.
    match /notifications/{notifId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && (request.resource.data.createdAt == null
                        || request.resource.data.createdAt == request.time)
                    && !(request.resource.data.type in [
                        "shift_reminder_1h",
                        "tv_offline",
                        "tv_back_online",
                        "i9_reverify_due",
                        // 2026-05-26 — owner-inbox-triage types are
                        // CF-only (written by pollGmail). Clients
                        // never need to create one and absolutely
                        // shouldn't be able to forge a fake catering
                        // inquiry / complaint that would page the
                        // owners + cost SMS spend.
                        "email_inquiry_catering",
                        "email_inquiry_complaint",
                        // 2026-05-26 — CF-only. pollGmail pings owners
                        // when the classifier returns low confidence.
                        "email_needs_classification",
                        // 2026-05-26 — bug-logging critical-error alert.
                        // Written exclusively by onCriticalError CF when
                        // a row lands in /error_logs with severity ===
                        // 'critical'. Blocking client mint prevents a
                        // tampered client from forging a fake crit
                        // page to spam the owners.
                        "critical_error_alert",
                    ]);
      allow update: if request.resource.data is map;
      allow delete: if false;
    }

    // ── email_intel — owner inbox triage payload (CF-only writes) ──────
    // Written exclusively by the pollGmail Cloud Function (admin SDK
    // bypasses these rules). Clients READ for the InboxTriage admin
    // tab; UI is gated to ids 40/41 in App.jsx + Sidebar. Phase 2
    // (Firebase Auth + custom claims) will tighten reads to owners
    // only; until then any apiKey-holder can technically read these,
    // which is why subjects/snippets stay short and bodies stay out.
    //
    // 2026-05-26 update — added narrow client UPDATE allow so the
    // InboxTriage UI can:
    //   - mark items triaged
    //   - manually reclassify (category + manuallyCorrected* fields)
    //   - stamp forwardedToStaff after a manual send-to-staff
    // No create/delete from clients. Without Firebase Auth this is
    // open to anyone with the apiKey, but the same caveat applies to
    // every other client-writable path in the app today — Phase 2
    // will close it via custom claims.
    match /email_intel/{id} {
      allow read: if true;
      allow create, delete: if false;
      allow update: if request.resource.data is map;
    }

    // ── email_intel_corrections — manager-supplied training signal ─────
    // Append-only. Each row records a manual reclassification: who
    // changed it, when, and from→to. pollGmail loads the most recent
    // 30 as few-shot examples in the classification prompt so the
    // model picks up the owner's preferences over time. No updates
    // or deletes — corrections are immutable history.
    match /email_intel_corrections/{id} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.newCategory in
                       ['catering','complaint','vendor','bill','toast','other'];
      allow update, delete: if false;
    }

    // ── system/* — Cloud Function bookkeeping (no client access) ───────
    // gmail_sync_state, gmail_sync_lock, etc. The InboxTriage component
    // subscribes to system/gmail_sync_state for the setup banner so we
    // allow read; everything else stays CF-only.
    match /system/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── error_logs — frontend + Cloud Function crash dumps ─────────────
    // Written by src/data/logger.js (logError) and by Cloud Functions
    // when they hit an unhandled exception. Read by AdminHealthPage
    // (owner-only client gate) to surface the recent-errors card and
    // by the onCriticalError CF to dispatch SMS alerts.
    //
    // Append-only from clients. Cloud Functions use the admin SDK and
    // bypass these rules, so server-side cleanup via pruneLogs() works.
    // No updates from clients — if we ever need "marked resolved" we'll
    // do it via a callable so the actor is auditable.
    //
    // Shape narrowing: errorMessage + severity + ts. We do NOT validate
    // every field because the logger may add legitimate ones in future
    // (sessionId, breadcrumbs, etc.) and rules-level validation is
    // brittle. Keeps the bar at "this is a real log row, not garbage."
    //
    // Without Firebase Auth (Phase 2) we can't truly restrict READS to
    // owners only. AdminHealthPage's tab gate (staffIsAdmin) is the
    // current line of defense; Phase 2 will tighten via custom claims.
    match /error_logs/{logId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.severity is string
                    && request.resource.data.errorMessage is string;
      allow update, delete: if false;
    }

    // ── security_logs — perm-denied, login retries, ownerOnly probes ───
    // Same posture as error_logs (append-only from clients, CF cleanup
    // via admin SDK). Phase 2 should restrict READS to owners only.
    match /security_logs/{logId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.kind is string;
      allow update, delete: if false;
    }

    // ── ai_logs — AI request/response telemetry ────────────────────────
    // Written exclusively by Cloud Functions (aiSearch, pollGmail
    // classifier, etc.). Clients can READ for the Health dashboard's
    // "AI failures" card. CF-only writes prevent a tampered client from
    // forging fake AI usage to spike Anthropic spend tracking.
    match /ai_logs/{logId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── api_request_logs — outgoing-API call telemetry ────────────────
    // Same posture as ai_logs. Cloud Functions write to track Toast,
    // Sysco, USFoods, Sling, Gmail, Twilio call results. Clients read
    // for the Health dashboard's API-health card.
    match /api_request_logs/{logId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── bug_reports — staff-submitted bug reports ──────────────────────
    // Written by ReportProblemButton (any signed-in staff can file).
    // UPDATES are allowed because the Health dashboard's "Resolve"
    // button writes status + resolvedAt + resolvedBy. We narrow update
    // to require the status field be one of a fixed set so a buggy
    // client can't junk-write the whole doc.
    //
    // Reads are open at the rules level today (Phase-2 Auth + claims
    // would gate to owners + the reporter only). The Phase-1 mitigation
    // is the AdminHealthPage tab gate; the data we capture is already
    // redacted via src/data/redact.js so even if a curious staff
    // member ran getDocs() they'd see no PII bodies.
    match /bug_reports/{reportId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.description is string
                    && request.resource.data.description.size() > 0
                    && request.resource.data.description.size() <= 2500;
      allow update: if request.resource.data is map
                    && request.resource.data.status in
                       ['open','investigating','resolved','duplicate','wontfix'];
      allow delete: if false;
    }

    // ── TV displays + devices ──────────────────────────────────────────
    // tv_configs is the menu-board config (label, layout, dayparts).
    // tv_heartbeats is written by MenuDisplay every 60s. Both should be
    // narrowed: the catch-all below would otherwise allow anyone with
    // the apiKey to wipe the entire signage system.
    //
    // Heartbeat writes must include the tvId on the doc itself + a
    // request-time lastSeenAt to prevent forging "device was here"
    // entries with backdated timestamps. Block delete entirely on
    // heartbeats — admin can let stale entries age out naturally
    // (checkTvHeartbeats CF prunes them server-side).
    match /tv_configs/{tvId} {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if true;   // admin removes TVs via the dashboard

      // Version history subcollection (Andrew 2026-05-23) — every
      // save / publish-from-draft / rollback archives the prior
      // published state here. Reads stay open so the History modal
      // can list them; creates are required to be maps. We allow
      // delete because admins may eventually want to prune old
      // versions, and at this layer there's no PII to protect
      // (each row is a TV-config snapshot, no staff data).
      match /versions/{versionId} {
        allow read: if true;
        allow create, update: if request.resource.data is map;
        allow delete: if true;
      }
    }
    // Hardened 2026-05-30 (CR-5): require lastSeenAt to be exactly the
    // server-side request.time. The old rule permitted lastSeenAt == null
    // which let a hostile client mask an offline TV by writing a heartbeat
    // with null timestamp — `checkTvHeartbeats` would skip the staleness
    // check on a null and the owner-alert never fires. MenuDisplay always
    // writes a fresh serverTimestamp on heartbeat, so banning null does
    // not affect legitimate clients.
    match /tv_heartbeats/{tvId} {
      allow read: if true;
      allow create, update: if request.resource.data.tvId is string
                            && request.resource.data.lastSeenAt == request.time;
      allow delete: if false;
    }

    // ── Print job log ──────────────────────────────────────────────────
    // sendToPrinter writes one /print_jobs row per attempt (success
    // or failure). The Label Printing Center reads this collection.
    // Append-only — once logged, the row never changes.
    match /print_jobs/{jobId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && (request.resource.data.createdAt == null
                        || request.resource.data.createdAt == request.time);
      allow update, delete: if false;
    }

    // ── TV pairing codes — short-TTL, single-use ──────────────────────
    // 6-digit codes generated by the admin-side PairDeviceModal and
    // consumed by the Pi-side PairDevicePage. Lifecycle:
    //   create  — admin mints a code with TTL 10 min
    //   update  — Pi claims (writes claimedAt + deviceId) OR admin
    //             assigns (writes assignedTvId)
    //   delete  — admin abandons (cancelPairingCode), or anyone can
    //             clean up an expired entry
    // Code expiry is enforced by the client transaction in
    // claimPairingCode; rules just narrow the WRITE SHAPE so a
    // hostile client can't forge an assignedTvId on someone else's
    // active code (the actual concurrent-claim guard is the
    // runTransaction in src/data/devicePairing.js).
    match /pairing_codes/{code} {
      allow read: if true;
      allow create: if request.resource.data.code is string
                    && request.resource.data.code.size() == 6
                    && request.resource.data.expiresAt is timestamp;
      allow update: if request.resource.data is map
                    && request.resource.data.code == resource.data.code;
      allow delete: if true;
    }

    // ── PTO / time off — shape-validated ───────────────────────────────
    // /time_off rows are PTO requests with staff name + date range +
    // approval status. Updates are open shape so the approve / deny /
    // reverse flow works. Delete is a DELIBERATE feature (Andrew
    // 2026-06-10: managers can delete a request outright, and staff can
    // cancel their own) — it previously said `if false` here but worked
    // anyway via the {document=**} catch-all; made explicit so Phase 2
    // hardening of the catch-all doesn't silently kill the delete flows
    // (PtoActionChips 🗑, handleRemoveTimeOff, handleCancelOwnPto).
    match /time_off/{requestId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && (request.resource.data.createdAt == null
                        || request.resource.data.createdAt == request.time);
      allow update: if request.resource.data is map;
      allow delete: if true;
    }

    // ── /insurance — benefits enrollment (CR-1, 2026-05-30) ──────────────
    // 2026-06-02 doc-ID hardening — NEW enrollments use Firestore-
    // generated random doc IDs (see InsuranceEnrollment.jsx
    // handleSubmit). The staffName → docId mapping lives at
    // /config/insurance_index. Pre-migration records still live at
    // the legacy predictable ID `staffName.toLowerCase().replace(...)`;
    // a one-shot migration script (Andrew TODO) is the vehicle to
    // rewrite them. Until that ships, BOTH ID shapes are valid here.
    //
    // KNOWN PHASE-2 GAP: without Firebase Auth, anyone with the public
    // apiKey can still LIST the collection (and now also READ the
    // index doc) — there is no Auth-less fix for that. Random IDs
    // close the "guess by name" attack but not the "list collection"
    // attack. The Phase 2 roadmap at the top of this file is the only
    // real lock. What we CAN enforce now:
    //   • Block client-side deletes — benefits-enrollment history must
    //     not be wipable from DevTools.
    //   • Make staffName immutable on update — stops a hostile client
    //     from rewriting whose record this is.
    //   • Map-shape check rejects garbage writes.
    // Cloud Functions (admin SDK) bypass these rules for any legitimate
    // server-side cleanup.
    match /insurance/{docId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.staffName is string;
      allow update: if request.resource.data is map
                    && request.resource.data.staffName is string
                    && request.resource.data.staffName == resource.data.staffName;
      allow delete: if false;
    }

    // ── /config/insurance_index — random-ID lookup table (2026-06-02) ────
    // Maps staffName → random doc ID inside /insurance. Used to
    // de-couple the insurance doc ID from the publicly-listable
    // /config/staff names so a curious apiKey holder can't getDoc()
    // someone's PII by guessing the name-derived legacy ID.
    //
    // Shape: { entries: { [staffName]: docId }, updatedAt }.
    //
    // POSTURE: read is currently open because anonymous Firestore +
    // no Auth means we can't actually restrict to admins server-side.
    // This is a defense-in-depth improvement, not a hard lock —
    // raises the bar from "guess the convention" to "discover this
    // specific doc path and read it." Phase 2 (Firebase Auth +
    // canViewInsurance claim) closes it properly.
    //
    // Writes are shape-validated. Block delete entirely — wiping
    // the index would orphan every random-ID insurance record from
    // its staff name and break the load path.
    match /config/insurance_index {
      allow read: if true;
      allow create, update: if request.resource.data is map
                            && request.resource.data.entries is map;
      allow delete: if false;
    }

    // ── /tardies — tardiness records (CR-2, 2026-05-30) ──────────────────
    // Written by TardinessTracker (addDoc on punch-in, updateDoc to
    // toggle excused, deleteDoc when admin removes). Previously fell
    // through to catch-all so any apiKey holder could forge a tardy
    // record (false attendance write-up). Tighten the create shape and
    // keep delete open because the dashboard removes entries.
    match /tardies/{tardyId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.staffName is string;
      allow update: if request.resource.data is map;
      allow delete: if true;   // admin removes via dashboard
    }

    // ── /maintenanceRequests — ticket queue (CR-2, 2026-05-30) ───────────
    // Written by MaintenanceRequest (staff submits) and AdminPanel
    // (admin updates status, deletes resolved). Tighten create shape;
    // delete stays open for admin cleanup.
    match /maintenanceRequests/{id} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.description is string;
      allow update: if request.resource.data is map;
      allow delete: if true;
    }

    // ── /offsite_shifts — off-property clock-ins (CR-2, 2026-05-30) ──────
    // Written by src/data/offsiteClock.js (addDoc on clock-in,
    // updateDoc on clock-out / break / note). Clock-in history is
    // payroll-adjacent — block client deletes; the audit trail must
    // survive even if a manager wants to "tidy up."
    match /offsite_shifts/{id} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.staffName is string;
      allow update: if request.resource.data is map;
      allow delete: if false;
    }

    // ── /cateringOrders — catering inquiry / order log (CR-2, 2026-05-30) ─
    // Written by CateringOrder (addDoc + setDoc on update). No client
    // delete path exists today; lock it down so spammed/forged orders
    // can't be silently erased from history before owners review.
    match /cateringOrders/{id} {
      allow read: if true;
      allow create: if request.resource.data is map;
      allow update: if request.resource.data is map;
      allow delete: if false;
    }

    // ── /sms_delivery_logs — CF-only writes (CR-2, 2026-05-30) ───────────
    // dispatchSms (functions/sms.js) and twilioStatusCallback write
    // every SMS attempt/result here via admin SDK (bypasses these
    // rules). Clients READ for the Health dashboard. Sealing client
    // writes prevents a tampered client from forging fake delivery
    // success entries to hide failed sends (or vice versa).
    match /sms_delivery_logs/{logId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── /sms_inbound_events — CF-only writes (CR-2, 2026-05-30) ──────────
    // twilioInbound webhook writes via admin SDK. Inbound STOP/START/HELP
    // events drive compliance — clients should never mint or alter them.
    match /sms_inbound_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── /sms_opt_in_events — CF-only writes (CR-2, 2026-05-30) ───────────
    // Audit trail of consent changes (functions/sms.js). Append-only
    // server-side. Clients READ for the staff usage dashboard's opt-in
    // history; sealing writes prevents tampering.
    match /sms_opt_in_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── /staff_deletion_requests (2026-05-31) ────────────────────────────
    // Apple + Google App Store compliance — staff must be able to
    // request account deletion from inside the app. Owner approves
    // within 7 days (Apple's guideline) then a manual/CF action
    // does the actual record removal.
    //
    // Create — anyone with the public apiKey CAN submit a request
    // for themselves. Without auth wired up yet, we cannot verify
    // the requester IS the named staff — worst-case is spurious
    // requests, which admin sees in the queue and dismisses. No
    // PII risk in the request doc itself.
    //
    // Update — admins flip to approved/rejected; the requester can
    // self-withdraw a pending request. Allowed status values are
    // pinned to the valid lifecycle states.
    //
    // Delete — never. Keep the trail for compliance.
    //
    // Hardened 2026-06-02 (Phase 1 audit). Previously the update rule
    // allowed any of pending/withdrawn/approved/rejected from a client
    // — meaning anyone with the apiKey could mark another staff's
    // request "approved" and trigger the downstream deletion flow.
    // Approved + rejected transitions are admin-only and happen via
    // the admin Cloud Function (admin SDK bypasses these rules), so
    // we restrict client updates to ONE transition: pending →
    // withdrawn (the requester self-cancels a pending request).
    match /staff_deletion_requests/{reqId} {
      allow read: if true;
      allow create: if request.resource.data is map
        && request.resource.data.requesterName is string
        && request.resource.data.status == 'pending';
      // Client can only flip pending → withdrawn. Any other transition
      // (approve / reject / revive) goes through a Cloud Function.
      allow update: if request.resource.data is map
        && resource.data.status == 'pending'
        && request.resource.data.status == 'withdrawn';
      allow delete: if false;
    }

    // ── /needs_webster + /needs_maryland (2026-06-02, Phase 1 audit) ─────
    // Per-location supply request board (one-off needs like brooms,
    // pans, stickers — see NeedsBoard.jsx). Previously silently
    // inherited the catch-all below; lifting it out so the create
    // shape is enforced server-side:
    //   • text is a non-empty string
    //   • urgency in [urgent, soon, no_rush]
    //   • status in [open, resolved]
    //
    // Updates happen for two flows (toggleResolved, cycleUrgency) —
    // we keep the update shape map-typed (rules can't statically
    // validate which subset of fields changed without a full diff).
    // Delete stays open because admin removes resolved entries via
    // the dashboard (with a confirm prompt client-side).
    //
    // NOTE: Firestore rules do NOT support partial-segment variable
    // substitution (same caveat as inventory_audits_{location}
    // above). Each location gets its own explicit match block.
    match /needs_webster/{needId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.urgency in ['urgent', 'soon', 'no_rush']
                    && request.resource.data.status in ['open', 'resolved'];
      allow update: if request.resource.data is map
                    && (!('urgency' in request.resource.data)
                        || request.resource.data.urgency in ['urgent', 'soon', 'no_rush'])
                    && (!('status' in request.resource.data)
                        || request.resource.data.status in ['open', 'resolved']);
      allow delete: if true;       // admin cleanup
    }
    match /needs_maryland/{needId} {
      allow read: if true;
      allow create: if request.resource.data is map
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.urgency in ['urgent', 'soon', 'no_rush']
                    && request.resource.data.status in ['open', 'resolved'];
      allow update: if request.resource.data is map
                    && (!('urgency' in request.resource.data)
                        || request.resource.data.urgency in ['urgent', 'soon', 'no_rush'])
                    && (!('status' in request.resource.data)
                        || request.resource.data.status in ['open', 'resolved']);
      allow delete: if true;       // admin cleanup
    }

    // Hire-initiated invite-recovery requests. Written from the PUBLIC
    // lock screen (HomePage.jsx#RecoverInviteModal) when a new hire lost
    // their /?onboard=TOKEN link. The resendOnboardingInvite Cloud
    // Function (server-only) reads these on create, looks up the hire by
    // email, mints/refreshes a /onboarding_invites/{token} doc, and
    // emails the new link. The function flips status to 'sent' /
    // 'no_match' / 'error' from the server with admin credentials —
    // clients cannot.
    //
    // Posture mirrors /onboarding_applications:
    //   - Reads stay open (the catch-all already permits this; admins
    //     occasionally inspect the queue from the Onboarding tab).
    //   - Create requires a non-empty email + status === 'pending' +
    //     serverTimestamp requestedAt. Blocks the obvious garbage shape.
    //   - Update / delete from clients are blocked outright. The hire
    //     can't edit their request after it's sent; the Cloud Function
    //     uses admin SDK which bypasses these rules.
    match /onboarding_invite_recovery_requests/{reqId} {
      allow read: if true;
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 4
                    && request.resource.data.email.size() < 200
                    && request.resource.data.status == 'pending'
                    && request.resource.data.requestedAt == request.time;
      allow update, delete: if false;
    }

    // ── Catch-all ──────────────────────────────────────────────────────
    // Every other collection inherits a permissive default. KNOWN GAP
    // (re-affirmed 2026-06-02, Phase 1 audit): this is the single
    // biggest remaining security weakness in the rules. Any collection
    // not explicitly listed above (shifts, vendor_*, staff_todos,
    // swap_requests, scheduled_messages, required_tasks,
    // calendar_events, etc.) is fully writable by anyone holding the
    // public Firebase apiKey. The Phase 2 roadmap at the top of this
    // file is the correct fix — Firebase Auth + custom claims + App
    // Check. Until that lands, casual abuse is mitigated by: (a) the
    // audit logs on each meaningful action, (b) the PIN screen +
    // idle relock keeping random walkup access out, and (c) write-
    // shape validation on the highest-PII paths immediately above
    // this rule.
    //
    // The narrowing applied here: every catch-all CREATE/UPDATE must
    // be a map payload. Rejects the kind of raw-string or null
    // writes that come from buggy clients. Deletes stay open because
    // the catch-all covers many collections that legitimately
    // delete docs (shifts, date_blocks, staff_todos, swap_requests,
    // scheduled_messages, recipe_views, etc.) — folding delete into
    // a payload-shape check would silently break all of them
    // (request.resource is null on delete, so `request.resource.data
    // is map` evaluates to false).
    match /{document=**} {
      allow read: if true;
      allow create, update: if request.resource.data is map;
      allow delete: if true;
    }
  }
}
