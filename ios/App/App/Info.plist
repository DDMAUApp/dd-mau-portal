<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>DD Mau</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- 2026-05-31 — Permission usage descriptions. Apple rejects apps that
	     request permissions without honest, specific copy here. Each string
	     gets shown verbatim in the OS permission prompt. -->
	<key>NSCameraUsageDescription</key>
	<string>DD Mau uses the camera so you can attach photos of supply issues to chat and maintenance tickets, and capture your ID during onboarding.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DD Mau uses the microphone to record voice notes in chat.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DD Mau lets you attach photos from your library to chat and maintenance tickets.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>DD Mau saves PDFs of your onboarding paperwork to your photo library so you keep a personal copy.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DD Mau uses your location only when you are at work to confirm you are inside the restaurant for clock-in.</string>
	<!-- Allow files from the iOS Files app + iCloud Drive when attaching documents. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
</dict>
</plist>
