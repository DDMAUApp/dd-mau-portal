<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>DD Mau</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- 2026-06-01 — Andrew + Claude submission audit. Changed armv7 → arm64.
	     armv7 is the 32-bit ARM ISA which Apple dropped support for at iOS 11
	     (every device since iPhone 5s is arm64). Submitting with armv7
	     triggers an automated Apple validation warning. arm64 correctly
	     filters out the 32-bit-only iPhone 5/5c/4s which can't run any
	     modern Swift Capacitor build anyway. -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<!-- 2026-06-01 — App Store encryption export compliance.
	     Setting this to false declares we only use standard HTTPS/TLS
	     (no custom crypto). Without this key, App Store Connect blocks
	     every TestFlight build asking you to fill in the encryption
	     export form. Standard HTTPS via Firebase + iOS system APIs is
	     exempt under U.S. export regulations 15 CFR 740.17(b)(1). -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- 2026-06-01 round 5 — Andrew: "the very top where the phone time
	     is located is not visible because the time is white with the
	     background as white. make the font black."
	     Root cause: when UIViewControllerBasedStatusBarAppearance is
	     true, iOS reads the WebView container's preferredStatusBarStyle.
	     On iOS 17+ that defaults to .default which goes WHITE in any
	     system-level dark context — even if our app is light. Forcing
	     this to FALSE makes iOS read UIStatusBarStyle below globally,
	     which we pin to DarkContent (dark text, dark icons). Combined
	     with UIUserInterfaceStyle = Light below this also stops iOS
	     auto-flipping the app to dark mode at the OS level. -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDarkContent</string>
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>
	<!-- 2026-05-31 — Permission usage descriptions. Apple rejects apps that
	     request permissions without honest, specific copy here. Each string
	     gets shown verbatim in the OS permission prompt. -->
	<key>NSCameraUsageDescription</key>
	<string>DD Mau uses the camera so you can attach photos of supply issues to chat and maintenance tickets, and capture your ID during onboarding.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DD Mau uses the microphone to record voice notes in chat.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DD Mau lets you attach photos from your library to chat and maintenance tickets.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>DD Mau saves PDFs of your onboarding paperwork to your photo library so you keep a personal copy.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DD Mau uses your location only when you are at work to confirm you are inside the restaurant for clock-in.</string>
	<!-- Allow files from the iOS Files app + iCloud Drive when attaching documents. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
</dict>
</plist>
