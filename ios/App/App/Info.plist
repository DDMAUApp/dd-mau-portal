<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- 2026-06-06 — Local-network label printing (Epson TM-L100, ePOS over
	     HTTP on the restaurant Wi-Fi). NSAllowsLocalNetworking permits
	     cleartext to LAN/private addresses ONLY — internet traffic stays
	     ATS-protected. NSLocalNetworkUsageDescription is required on iOS 14+
	     to reach a device on the local network. Used by CapacitorHttp.post()
	     in src/data/labelPrinting.js. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>DD Mau prints prep and date labels directly to the Epson label printer on your restaurant Wi-Fi.</string>
	<!-- Face ID for faster staff sign-in (optional; PIN always works). Used by
	     @capgo/capacitor-native-biometric via src/data/biometrics.js. -->
	<key>NSFaceIDUsageDescription</key>
	<string>Use Face ID to sign in to DD Mau faster. Your PIN still works as a backup.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>DD Mau</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- 2026-06-01 — Andrew + Claude submission audit. Changed armv7 → arm64.
	     armv7 is the 32-bit ARM ISA which Apple dropped support for at iOS 11
	     (every device since iPhone 5s is arm64). Submitting with armv7
	     triggers an automated Apple validation warning. arm64 correctly
	     filters out the 32-bit-only iPhone 5/5c/4s which can't run any
	     modern Swift Capacitor build anyway. -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<!-- 2026-06-01 — App Store encryption export compliance.
	     Setting this to false declares we only use standard HTTPS/TLS
	     (no custom crypto). Without this key, App Store Connect blocks
	     every TestFlight build asking you to fill in the encryption
	     export form. Standard HTTPS via Firebase + iOS system APIs is
	     exempt under U.S. export regulations 15 CFR 740.17(b)(1). -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- 2026-06-03 — Added PortraitUpsideDown to both arrays. Xcode warning
	     "All interface orientations must be supported unless the app
	     requires full screen." Apple's iPad requirement is that an app
	     must either declare all 4 orientations OR set UIRequiresFullScreen.
	     We support all 4 (rare on iPhone, common on iPad) — preferable to
	     locking full-screen, which would disable iPad multitasking
	     (Slide Over / Split View) and reduce App Store discoverability. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- 2026-06-01 round 5 — Andrew: "the very top where the phone time
	     is located is not visible because the time is white with the
	     background as white. make the font black."
	     Root cause: when UIViewControllerBasedStatusBarAppearance is
	     true, iOS reads the WebView container's preferredStatusBarStyle.
	     On iOS 17+ that defaults to .default which goes WHITE in any
	     system-level dark context — even if our app is light. Forcing
	     this to FALSE makes iOS read UIStatusBarStyle below globally,
	     which we pin to DarkContent (dark text, dark icons). Combined
	     with UIUserInterfaceStyle = Light below this also stops iOS
	     auto-flipping the app to dark mode at the OS level. -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDarkContent</string>
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>
	<!-- 2026-05-31 — Permission usage descriptions. Apple rejects apps that
	     request permissions without honest, specific copy here. Each string
	     gets shown verbatim in the OS permission prompt. -->
	<!-- 2026-06-02 — Stripped the "capture your ID during onboarding" clause.
	     Camera capture is used in chat (ChatThread, ChatPhotoIssueModal),
	     Maintenance (MaintenanceRequest), supply needs (NeedsBoard), Operations
	     checklists, and — since 2026-07-12 — the Health Department module
	     (vaccine-card / health-document photos via input capture in
	     HealthDepartment/HealthBulkEditor). Copy below must list every real
	     path; Apple rejects mismatched copy under 5.1.1(i). -->
	<key>NSCameraUsageDescription</key>
	<string>DD Mau uses the camera so you can attach photos to chat, maintenance tickets, supply-needs reports, and your own health records (like a vaccine card).</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DD Mau uses the microphone to record voice notes in chat.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DD Mau lets you attach photos from your library to chat and maintenance tickets.</string>
	<!-- NSPhotoLibraryAddUsageDescription removed 2026-06-02: no code path writes to Photos; PDFs save to Files via Filesystem + Share sheet. Re-add only if a future feature actually calls UIImageWriteToSavedPhotosAlbum / PHPhotoLibrary save. -->
	<!-- 2026-06-02 — Rewrote to match actual usage. Geolocation is read in
	     exactly ONE place: src/components/hooks/useGeofence.js, which the
	     Recipes page uses to confirm the device is inside the restaurant
	     before unhiding sensitive recipe details. There is NO clock-in
	     geolocation code path in the app — the old "clock-in" wording was
	     copied from an earlier plan that never shipped. Apple reviewers
	     reject mismatched copy under guideline 5.1.1(i). -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DD Mau uses your location only on the Recipes page to confirm you are inside the restaurant before showing sensitive recipe details.</string>
	<!-- 2026-06-05 — Apple delivery warning ITMS-90683 also wants the "always"
	     variant. We do NOT call requestAlwaysAuthorization anywhere — a linked
	     SDK (Capacitor Geolocation / GoogleAppMeasurement) references the
	     always-location API at the binary level, so Apple's static scanner
	     requires the matching purpose string even though the app only ever
	     reads location while open (the Recipes geofence). Copy mirrors the
	     when-in-use string and explicitly states we never track in the
	     background, so it stays truthful under guideline 5.1.1(i). -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>DD Mau uses your location only on the Recipes page to confirm you are inside the restaurant before showing sensitive recipe details. The app never tracks your location in the background.</string>
	<!-- Allow files from the iOS Files app + iCloud Drive when attaching documents. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<!-- 2026-06-02 — Added remote-notification background mode. Required so
	     FCM/APNs content-available silent pushes from the dispatchNotification +
	     sendShiftReminders Cloud Functions can wake a suspended/killed app to
	     update badges and pre-fetch data. Must be paired with Push Notifications
	     capability + aps-environment entitlement in Xcode (owner action). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
