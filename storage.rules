// DD Mau Firebase Storage rules
//
// Onboarding documents live here under /onboarding/{hireId}/{docId}/...
// These are HIGH-VALUE PII (SSN cards, DL photos, W4, direct deposit).
//
// Two access paths:
//   1. New hire uploading via the portal — they have an invite token in
//      their URL. The token is validated in Firestore by the client; for
//      Storage, we currently allow public writes inside the onboarding
//      path because token-validation at upload time would require a Cloud
//      Function proxy. Mitigations:
//        - Strict size cap (10 MB per file)
//        - Content-type allowlist (image/* + pdf only)
//        - Audit trail in Firestore for every upload
//        - The PATH includes the hireId — abuse means dumping into a
//          random hireId, which the admin will see and prune
//   2. Admin reading/downloading — gated by the canViewOnboarding flag
//      client-side. Until we wire per-user auth, Storage read is open;
//      the protection is path obscurity (hireId is a UUID) + the admin-
//      only UI surface.
//
// TODO (Phase 2): Wire Firebase Auth so admin reads can be gated by
// custom claim. For now, treat this as defense-in-depth around the
// client gate.
//
// Deploy: firebase deploy --only storage:rules

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────────────
    //  ⚠️  HIGHEST-PRIORITY PHASE 2 ITEM  ⚠️
    // ─────────────────────────────────────────────────────────────────────
    // The /onboarding/** read rule below is `allow read: if true`. That
    // means ANYONE who knows (or guesses) a /onboarding/{hireId}/{docId}/
    // {fileName} path can download the raw PII file — SSN-bearing W-4s,
    // I-9 photo IDs, voided checks with bank routing numbers.
    //
    // Mitigations in place today (defense-in-depth, NOT a real lock):
    //   • hireId is a Firestore-random doc id (can't be enumerated
    //     without listing /onboarding_hires, which is itself behind
    //     the apiKey gate)
    //   • fileName carries an internal timestamp prefix so it's not
    //     guessable from the hire's name alone
    //   • Every admin view / download writes /onboarding_audits
    //
    // The CORRECT FIX is a signed-URL proxy: a callable Cloud Function
    // `getOnboardingFileUrl({ hireId, docId, fileName })` that:
    //   1. verifies the caller's Auth claim (canViewOnboarding, the
    //      same gate the admin tab uses client-side today)
    //   2. mints a short-lived (5-min) signed URL via the Admin SDK
    //   3. returns it to the client to fetch the actual bytes
    // and once that's live, swap this block's `allow read: if true`
    // to `allow read: if false`.
    //
    // We are NOT shipping that proxy in this pass (it's a Phase 2 task
    // alongside Firebase Auth + custom claims). Marking it inline here
    // so the next engineer sees the alarm.
    //
    // What WE DID change in this pass (2026-06-02, Phase 1 audit):
    //   • `allow delete: if true` → `allow delete: if false`. Previously
    //     any apiKey holder could mass-delete the entire PII storage
    //     tree, breaking every hire's submitted paperwork. The handful
    //     of legitimate delete callsites (admin re-uploads, cleanup)
    //     will move to a Cloud Function with admin SDK access. Today,
    //     the worst case is "admin can't delete an old W-4 from the
    //     UI" — a far smaller surface than "anyone can wipe the bucket."
    match /onboarding/{hireId}/{docId}/{fileName} {
      allow read: if true;       // admin-only via client gate — SEE WARNING ABOVE
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      // Hardened 2026-06-02 (Phase 1 audit). Was `if true` — blocks
      // mass-delete abuse. Legitimate admin re-uploads can re-write the
      // file at the same path (`write` still passes); legitimate
      // cleanup of orphaned files lives in a Cloud Function path.
      allow delete: if false;
    }

    // Onboarding fillable PDF templates — admin uploads the blank source
    // PDFs (W-4, MO W-4, Direct Deposit). 15 MB cap is generous so
    // multi-page forms with embedded images fit comfortably. PDF only.
    match /onboarding_templates/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
      allow delete: if true;
    }

    // Optional resume uploads from public job applications. Same posture
    // as /onboarding except the path is /applications/{appId}/* — files
    // are uploaded BEFORE the applicant is a hire. Mitigations:
    //   - 10 MB cap (applicants aren't uploading photos of every doc)
    //   - PDF + image content-type allowlist
    //   - applicationId is the random Firestore doc id; orphans are
    //     visible in Storage and pruned by the lifecycle Cloud Function
    //     when the application is deleted at 180 days.
    match /applications/{appId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if true;
    }

    // Chat attachments — photos, voice notes, short videos.
    //
    // Hardened 2026-05-17 (AUDIT CHAT-001). Previously these uploads
    // fell through to the open catch-all below, so the 50 MB client-
    // side cap in ChatThread.jsx was bypassable from DevTools. A
    // scripted attacker could fill the bucket arbitrarily.
    //
    // 250 MB cap matches the client check (MAX_VIDEO_BYTES in
    // ChatThread.jsx). Content type restricted to image/* | video/* |
    // audio/* — chat never uploads arbitrary file types.
    //
    // Path: chats/{chatId}/{messageId}.{ext}. See ChatThread.jsx
    // handleMediaPick + uploadVoice for the producer side.
    //
    // 2026-07-07 — raised 50 MB → 250 MB (owner request): staff phone
    // videos of 2-3 minutes routinely exceed 50 MB, and real uploads
    // were being rejected. 250 MB covers normal clips while still
    // bounding a scripted bucket-fill.
    match /chats/{chatId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 250 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|video/.*|audio/.*');
      allow delete: if true;     // hard-delete cascade from chat purge
    }

    // Announcement banners + photos. Posted by managers via the
    // ChatAnnouncementComposer. Same posture as chats/*/.
    //
    // Path: chats/announcements/{announcementId}.{ext}. Image only —
    // composer doesn't accept video.
    match /chats/announcements/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Maintenance ticket photos. Submitted via MaintenanceRequest.jsx
    // by line staff reporting broken equipment / cleaning issues.
    //
    // Hardened 2026-05-17 (AUDIT MAINT-001). Image only, 10 MB cap —
    // a kitchen photo is rarely above 5 MB after iOS auto-compression.
    //
    // Path: maintenance/{ticketId}/{fileName} — see MaintenanceRequest.jsx.
    match /maintenance/{ticketId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Health Department records — vaccine cards, food-handler certs
    // (HealthDepartment.jsx, 2026-07-12). Images + PDFs; no delete
    // (compliance artifacts are retained; replace by uploading anew).
    match /health/{staffId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
      allow delete: if false;
    }

    // Menu item photos — MenuEditor uploads.
    //
    // Hardened 2026-05-30 (CR-6, was bleeding through the catch-all).
    // Path: menu_photos/{slug}_{ts}.{ext} (MenuEditor.jsx). Image-only,
    // 10 MB cap is generous (typical compressed JPEG is well under 2 MB).
    match /menu_photos/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Maintenance ticket photos — legacy path used by MaintenanceRequest.jsx
    // (the /maintenance/{ticketId}/{fileName} block above is the newer
    // shape; this one is `maintenance-photos/{ts}_{name}`). Same posture.
    // CR-6, 2026-05-30: was inheriting the catch-all.
    match /maintenance-photos/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Checklist completion photos — Operations.jsx writes
    // `checklist-photos/{dateKey}/{taskId}_{ts}.jpg` whenever a staff
    // member attaches a proof photo to a task. CR-6, 2026-05-30.
    match /checklist-photos/{dateKey}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Needs Board attachments — NeedsBoard.jsx writes
    // `needs/{location}/{ts}_{name}.{ext}` when an admin/manager picks
    // a photo while filing a one-off supply request (brooms, pans,
    // stickers, etc.). 2026-06-02 (autonomous code reviewer): without
    // this block the photo upload silently 403s against the CR-6
    // catch-all `write: if false` — the React try/catch then shows the
    // generic "Could not save" alert and no photo is ever attached.
    // Image-only, 10 MB cap (same posture as maintenance / checklist
    // photos above).
    match /needs/{location}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;     // admin cleanup on need delete
    }

    // TV signage images + videos (2026-06-02, Phase 1 audit).
    // Path: tv_images/{slugPrefix}_{ts}.{ext}.
    // Producers:
    //   • TvConfigsEditor (uploadMenuFile) — admin uploads source PDFs,
    //     images, or videos that become menu-board art. PDFs are
    //     rasterized client-side to PNG before upload (so the rule
    //     never sees the original PDF mime), so we accept PNGs.
    //   • DaypartEditor — same upload path for daypart art.
    //   • menuImageUpload.js bakes composited PNGs into tv_images/
    //     after combining background + overlay.
    //
    // Was silently 403'ing against the CR-6 catch-all `write: if false`,
    // breaking every admin-side TV-art upload. Lifting it out with an
    // explicit rule. Generous cap (50 MB) because video files for
    // dayparts can be 20–30 MB after compression and we don't want to
    // re-encode them in the browser.
    match /tv_images/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|video/.*');
      allow delete: if true;     // admin re-uploads / TV cleanup
    }

    // Menu import staging path (2026-06-02, Phase 1 audit).
    // Path: menu_imports/{slugPrefix}_{ts}.{ext} — MenuImportModal
    // uploads source PDFs/images here as a temporary staging slot
    // when the admin is bulk-importing menu items from a vendor
    // export. Was also bleeding through CR-6 catch-all → import
    // failed silently.
    //
    // Same shape posture as tv_images: image + video allowed (video
    // for occasional motion-menu imports), generous 50 MB cap.
    match /menu_imports/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|video/.*|application/pdf');
      allow delete: if true;     // staging area — admin clears after import
    }

    // ── Catch-all ──────────────────────────────────────────────────────
    // Hardened 2026-05-30 (CR-6). The previous catch-all allowed both
    // read AND write on any unlisted path — meaning any new feature that
    // wrote to a path not listed above silently inherited zero size
    // cap, zero content-type allowlist, and zero rate ceiling. A scripted
    // attacker with the public apiKey could fill the bucket arbitrarily.
    //
    // New posture: reads stay open (the bucket serves public CDN-style
    // for now), but WRITES default-deny. Any new upload path MUST land
    // a matching `match` block above with explicit size + content-type
    // checks. If you see a "permission denied" on a Storage upload after
    // this change, the fix is to add a rule above — not to revert this.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
